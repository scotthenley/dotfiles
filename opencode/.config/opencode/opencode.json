{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [],
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      }
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse",
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": ["npx", "@bitbonsai/mcpvault@latest", "/Users/scotthenley/ObsidianVault"],
      "enabled": true
    },
    "lucid": {
      "type": "remote",
      "url": "https://mcp.lucid.app/mcp",
      "enabled": true
    },
    "aws-central": {
      "type": "local",
      "command": ["aws-vault", "exec", "central", "--", "uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "enabled": false
    },
    "aws-alli-staging": {
      "type": "local",
      "command": ["aws-vault", "exec", "alli-staging", "--", "uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "enabled": false
    },
    "aws-alli-prod": {
      "type": "local",
      "command": ["aws-vault", "exec", "alli-prod", "--", "uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "enabled": false
    },
    "aws-alli-shared": {
      "type": "local",
      "command": ["aws-vault", "exec", "alli-shared", "--", "uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "enabled": false
    }
  },
  "model": "openai/gpt-5.4",

  // Cheaper model for lightweight tasks (title generation, summaries)
  "small_model": "openai/gpt-5.4-mini",
}
