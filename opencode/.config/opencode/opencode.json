{
  "$schema": "https://opencode.ai/config.json",

  "theme": "tokyonight",

  "plugin": [
    "opencode-anthropic-auth@latest"
  ],
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PAT}"
      }
    },
    "aws-central": {
      "type": "local",
      "command": ["aws-vault", "exec", "central", "--", "uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "enabled": false
    },
    "aws-alli-staging": {
      "type": "local",
      "command": ["aws-vault", "exec", "alli-staging", "--", "uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "enabled": false
    },
    "aws-alli-prod": {
      "type": "local",
      "command": ["aws-vault", "exec", "alli-prod", "--", "uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "enabled": false
    },
    "aws-alli-shared": {
      "type": "local",
      "command": ["aws-vault", "exec", "alli-shared", "--", "uvx", "mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-east-1"],
      "enabled": false
    }
  },
  // Default model for general coding — best balance of quality + cost
  "model": "opencode/claude-sonnet-4-5",

  // Cheaper model for lightweight tasks (title generation, summaries)
  "small_model": "openai/gpt-5-nano",

  "provider": {
    "anthropic": {
      "models": {
        "claude-sonnet-4-5": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        }
      }
    },
    "openai": {
      "models": {
        "gpt-5.2-codex": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low"
          }
        },
        "gpt-5": {
          "options": {
            "reasoningEffort": "medium"
          }
        }
      }
    }
  },

  "agent": {
    // PRIMARY: Main coding agent — Sonnet for daily driver work
    "build": {
      "mode": "primary",
      "model": "opencode/claude-sonnet-4-5",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },

    // PRIMARY: Architecture & design planning — Opus for deep thinking
    "plan": {
      "mode": "primary",
      "model": "opencode/claude-opus-4-6",
      "temperature": 0.3,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },

    // SUBAGENT: Code review — Sonnet is great here, no write access
    "code-reviewer": {
      "description": "Reviews code for best practices, security, and potential issues",
      "mode": "subagent",
      "model": "opencode/claude-sonnet-4-5",
      "prompt": "You are a senior code reviewer. Focus on security vulnerabilities, performance bottlenecks, error handling, and maintainability. Be specific and actionable.",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },

    // SUBAGENT: Heavy implementation — Codex for complex multi-file work
    "implementer": {
      "description": "Handles complex multi-file implementations and refactoring",
      "mode": "subagent",
      "model": "openai/gpt-5.2-codex",
      "reasoningEffort": "high",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },

    // SUBAGENT: File search & codebase exploration — cheap and fast
    "explorer": {
      "description": "Explores codebase, finds files, answers questions about code structure",
      "mode": "subagent",
      "model": "openai/gpt-5-mini",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },

    // SUBAGENT: Debugging — GPT-5 is methodical here
    "debugger": {
      "description": "Investigates bugs, reads logs, traces issues",
      "mode": "subagent",
      "model": "openai/gpt-5",
      "reasoningEffort": "high",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    }
  }
}
